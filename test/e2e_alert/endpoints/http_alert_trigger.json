{
  "id": "ep_http_alert_trigger",
  "type": "endpoint/http",
  "name": "HTTP Alert Trigger",
  "configuration": {
    "ruleChainId": "rc-simple-e2e-test",
    "startNodeId": "node-route-by-severity",
    "httpMethod": "POST",
    "httpPath": "/alert",
    "description": "Triggers an alert via HTTP POST",
    "endpointDefinition": {
      "request": {
        "dtoName": "AlertTriggerReq",
        "bodyFields": [
          {
            "name": "severity",
            "type": "string",
            "required": true,
            "mapping": {
              "to": "dataT.asdflasjgie.Labels.severity",
              "defineSid": "parsedAlert"
            }
          },
          {
            "name": "summary",
            "type": "string",
            "required": true,
            "mapping": {
              "to": "dataT.asdflasjgie.Annotations.summary",
              "defineSid": "parsedAlert"
            }
          }
        ]
      },
      "response": {
        "dtoName": "AlertTriggerResp",
        "successCode": 200,
        "bodyFields": [
          {
            "name": "status",
            "mapping": {
              "to": "'ok'"
            }
          },
          {
            "name": "summary",
            "mapping": {
              "to": "dataT.asdflasjgie.Annotations.summary"
            }
          }
        ]
      }
    },
    "errorMappings": {
      "400": [
        "202501003"
      ],
      "500": [
        "202501001",
        "202501002"
      ]
    }
  }
}
